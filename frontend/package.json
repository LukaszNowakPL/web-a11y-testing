{
    "name": "web-a11y-testing-frontend",
    "type": "module",
    "private": true,
    "version": "0.0.0",
    "scripts": {
        "dev": "vite --port 3000",
        "build": "vite build",
        "test": "npm run test:functional && npm run test:snapshot",
        "test:windows": "npm run test:functional && npm run test:snapshot:windows",
        "test:functional": "playwright install chromium && playwright test --project=functional",
        "test:functional:debug": "playwright install chromium && playwright test --project=functional --debug",
        "test:snapshot": "playwright install chromium && playwright test --project=snapshot",
        "test:snapshot:windows": "playwright install chromium && npm run script:change-line-delimiter-to-windows && playwright test --project=snapshot && npm run script:change-line-delimiter-to-git",
        "test:snapshot:update": "playwright install chromium && playwright test --project=snapshot --update-snapshots",
        "test:snapshot:update:windows": "playwright install chromium && npm run script:change-line-delimiter-to-windows && playwright test --project=snapshot --update-snapshots && npm run script:change-line-delimiter-to-git",
        "lint": "eslint --report-unused-disable-directives --max-warnings=0 src",
        "typecheck": "tsc -noEmit",
        "prepare": "husky install",
        "reformat": "prettier --write \"+(src|test)/**/*\"",
        "prettier:check": "prettier --check .",
        "preview": "vite preview --port 9000 --host",
        "script:change-line-delimiter-to-windows": "node scripts/line-delimiter.mjs --tactic=git-to-windows",
        "script:change-line-delimiter-to-git": "node scripts/line-delimiter.mjs --tactic=windows-to-git"
    },
    "dependencies": {
        "@axe-core/playwright": "^4.10.1",
        "@babel/core": "^7.29.7",
        "@babel/eslint-parser": "^7.29.7",
        "@babel/plugin-transform-runtime": "^7.29.7",
        "@babel/preset-env": "^7.29.7",
        "@babel/preset-react": "^7.29.7",
        "@babel/preset-typescript": "^7.29.7",
        "@emotion/css": "^11.13.5",
        "@eslint/js": "^9.39.4",
        "@faker-js/faker": "^10.4.0",
        "@playwright/test": "1.60.0",
        "@radix-ui/react-icons": "^1.3.2",
        "@radix-ui/themes": "^3.2.0",
        "@remix-run/router": "^1.22.0",
        "@remix-run/web-fetch": "^4.4.2",
        "@tanstack/react-query": "^5.101.0",
        "@types/node": "^20.11.18",
        "@types/react": "^18.3.18",
        "@types/react-dom": "^18.3.5",
        "@vitejs/plugin-react": "^6.0.2",
        "axios": "^1.17.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-jsx-a11y": "^6.10.2",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.1.1",
        "factory.ts": "^1.4.2",
        "final-form": "^5.0.1",
        "lighthouse": "^13.4.0",
        "mockiavelli": "^1.3.1",
        "playwright-lighthouse": "^4.0.0",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "react-final-form": "^7.0.1",
        "react-router-dom": "^7.17.0",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.61.0",
        "vite": "^8.0.16",
        "vite-plugin-checker": "^0.14.1",
        "web-a11y-testing": "file:.."
    },
    "browserslist": {
        "production": [
            ">0.2%",
            "not dead",
            "not op_mini all"
        ],
        "development": [
            "last 1 chrome version",
            "last 1 firefox version",
            "last 1 safari version"
        ]
    }
}
